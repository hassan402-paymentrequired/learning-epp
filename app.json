{
  "expo": {
    "name": "Stepra",
    "slug": "stepra",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "stepra",
    "splash": {
  "image": "src/assets/images/splash-icon.png",
  "resizeMode": "cover",
  "backgroundColor": "#1E1B4B"
},
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "src/assets/images/splash-icon.png",
        "backgroundColor": "#1E1B4B"
      }
    },
    "web": {
      "favicon": "src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1E1B4B",
          "image": "src/assets/images/splash-icon.png",
          "resizeMode": "cover" 
        }
      ]
    ]
  }
}
