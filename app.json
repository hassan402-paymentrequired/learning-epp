{
  "expo": {
    "name": "Stepra",
    "slug": "stepra",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "src/assets/images/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "stepra",
    "splash": {
      "image": "src/assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1B4B"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "src/assets/images/logo.png",
        "backgroundColor": "#1E1B4B"
      },
      "package": "com.oluwafemiomoope.stepra",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "src/assets/images/favicon.png"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#1E1B4B",
      "translucent": false
    },
    "plugins": [
      "expo-asset",
      "./plugins/withAndroidLegacySplashFullscreen.js",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1E1B4B",
          "image": "src/assets/images/logo.png",
          "resizeMode": "contain",
          "imageWidth": 220,
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "src/assets/fonts/SpaceMono-Regular.ttf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2ddba5b9-45bf-4ee4-bc58-9488e7c8e496"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
